# Simple Production Dockerfile for testing
FROM node:20-alpine AS runner
WORKDIR /app

# Copy only built files (simulate production)
COPY public ./public
COPY package.json ./package.json

# Install only production dependencies
RUN npm install --production --no-optional && npm cache clean --force

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000

EXPOSE 3000

# Simple startup command
CMD ["echo", "PKM LocalKarya Production Ready - Replace with actual startup"]
